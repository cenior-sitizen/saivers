# Xiaomi Purifier Test — miIO provider (for real device)
# Copy to .env and fill in your values.

# Device IP (find via router or miio discover)
XIAOMI_PURIFIER_IP=172.29.16.195

# 32-char hex token (get via miio discover or token extractor)
XIAOMI_PURIFIER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model (default: zhimi.airp.cpa4 for Smart Air Purifier 4 Compact)
XIAOMI_PURIFIER_MODEL=xiaomi.airp.cpa4

# --- Home Assistant provider (alternative) ---
# Use Xiaomi MiOT Auto integration: Settings → Devices → Add Integration → "Xiaomi MiOT Auto"
# IMPORTANT: When adding, choose "Cloud" — local and automatic will NOT show entities.
# HOME_ASSISTANT_URL=http://localhost:8123
# HOME_ASSISTANT_TOKEN=your_long_lived_access_token
# XIAOMI_PURIFIER_ENTITY_ID=fan.xiaomi_air_purifier
